{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":semanticCommits", "group:monorepos", "group:recommended"],
  "dependencyDashboard": true,
  "prConcurrentLimit": 10,
  "prHourlyLimit": 5,
  "rangeStrategy": "bump",
  "baseBranchPatterns": ["main"],
  "postUpdateOptions": ["pnpmDedupe"],
  "schedule": ["after 9am every weekday", "before 5am every weekday"],
  "labels": ["dependencies"],
  "vulnerabilityAlerts": {
    "enabled": true,
    "schedule": ["at any time"],
    "labels": ["security", "dependencies"]
  },
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": false,
    "schedule": ["before 5am on Monday"]
  },
  "packageRules": [
    {
      "description": "patch :: group all, automerge via platform merge queue after 3-day cooldown",
      "groupName": "All patch updates",
      "matchUpdateTypes": ["patch"],
      "minimumReleaseAge": "3 days",
      "automerge": true,
      "platformAutomerge": true,
      "labels": ["dependencies", "patch", "automerge"]
    },
    {
      "description": "dev minor :: manual review required :: allows sanity check on e.g. new lint rules",
      "groupName": "Dev dependency minor updates",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor"],
      "minimumReleaseAge": "3 days",
      "automerge": false,
      "platformAutomerge": false,
      "labels": ["dependencies", "dev", "minor"]
    },
    {
      "description": "prod minor :: PR only, 5-day cooldown :: behavioral changes may affect users",
      "groupName": "Production dependency minor updates",
      "matchDepTypes": ["dependencies"],
      "matchUpdateTypes": ["minor"],
      "minimumReleaseAge": "5 days",
      "automerge": false,
      "labels": ["dependencies", "minor"]
    },
    {
      "description": "major :: manual review required, deprioritized in dashboard",
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true,
      "automerge": false,
      "groupName": "Major version updates",
      "labels": ["dependencies", "major", "breaking-change"],
      "prPriority": -1
    },
    {
      "description": "pnpm catalog :: exact pins have no range so replace is used instead of bump",
      "matchManagers": ["pnpm"],
      "matchDepTypes": ["pnpmCatalog"],
      "rangeStrategy": "replace",
      "automerge": false,
      "labels": ["dependencies", "catalog"]
    }
  ]
}
